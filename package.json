{
  "name": "teamspeak3-mcp",
  "version": "1.0.0",
  "description": "A Model Context Protocol (MCP) server for controlling TeamSpeak 3 from AI models",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "teamspeak3-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "teamspeak",
    "teamspeak3",
    "mcp",
    "model-context-protocol",
    "serverquery"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "ts3-nodejs-library": "^3.5.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
